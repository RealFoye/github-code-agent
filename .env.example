# GitHub Code Analysis Agent - 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ==================== LLM 提供者 ====================
# 可选: openai / deepseek / ollama / minimax
LLM_PROVIDER=minimax

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# DeepSeek 配置（备选）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# MiniMax 配置（使用 Anthropic SDK）
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# ==================== Embedding 配置 ====================
# 可选: openai / ollama / transformers
EMBEDDING_PROVIDER=openai

OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama 本地部署配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding

# ==================== GitHub API ====================
# 可选，有 GitHub Token 可以提高 API 限流（60次/时 → 5000次/时）
GITHUB_TOKEN=

# ==================== 搜索引擎（备选） ====================
SERPER_API_KEY=

# ==================== 日志级别 ====================
LOG_LEVEL=INFO
